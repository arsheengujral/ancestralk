# ─────────────────────────────────────────────────────────────────────────────
# Ancestralk — environment variables
# Copy to .env.local for local dev, or set these in your Vercel project settings.
# The app boots in a degraded/demo mode when a service isn't configured, so you
# can add these incrementally. NEXT_PUBLIC_* are exposed to the browser; the rest
# are server-only secrets and must never be prefixed NEXT_PUBLIC_.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (accounts, database, storage) — REQUIRED for saving anything ──────
# Project Settings → API. URL + publishable (anon) key are public; the secret
# (service_role) key is server-only and bypasses RLS — keep it secret.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App URL — your site's canonical address (used for auth redirects) ──────────
# Local: http://localhost:3000. Production: your stable Vercel domain, no slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AI features (optional — each unlocks one feature; app works without them) ──
# Anthropic: the written chapters + grammar/translate/tone (console.anthropic.com)
ANTHROPIC_API_KEY=
# OpenAI: voice → text transcription via Whisper (platform.openai.com)
OPENAI_API_KEY=

# ── Sealed future messages (optional) ──────────────────────────────────────────
# 32-byte base64 key used to AES-256-GCM encrypt sealed letters at rest.
# Generate one:  openssl rand -base64 32
FUTURE_MESSAGE_KEY=

# ── Scheduled jobs (REQUIRED for legacy transfer + future-message delivery) ────
# Shared secret the cron caller sends as:  Authorization: Bearer <CRON_SECRET>
# Set the same value on your Vercel Cron / scheduler.  openssl rand -hex 32
CRON_SECRET=

# ── Payments (optional) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Maps (optional) — leave blank to use free OpenStreetMap tiles ──────────────
NEXT_PUBLIC_MAPBOX_TOKEN=
