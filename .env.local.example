# ───────────────────────────────────────────────────────────────────────────
# Ancestralk — environment variables
# Copy to `.env.local` and fill in. The app runs in a graceful degraded/mock
# mode where keys are absent, so you can develop locally before wiring services.
# See README.md for where to obtain each key.
# ───────────────────────────────────────────────────────────────────────────

# Supabase — auth, Postgres, storage, RLS.  (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — story / biography / ask-archive generation (SERVER-SIDE ONLY).
# (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# OpenAI — Whisper voice transcription. (https://platform.openai.com)
OPENAI_API_KEY=

# Stripe — global payments ($60/yr). (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Razorpay — India payments (₹4,999/yr). (https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Mapbox — Family Map (Feature Set H). Leaflet/OSM is the no-key fallback.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Resend — transactional + future-message delivery email. (https://resend.com)
RESEND_API_KEY=

# Twilio — WhatsApp delivery for invites + future messages. (https://twilio.com)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# App base URL (used in invite + delivery links).
NEXT_PUBLIC_APP_URL=http://localhost:3000
